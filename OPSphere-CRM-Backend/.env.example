DATABASE_URL=postgresql://postgres:password@localhost:5432/opsphere
PORT=3003
JWT_SECRET=your-crm-jwt-secret-here
JWT_REFRESH_SECRET=your-crm-refresh-secret-here
CORS_ORIGIN=http://localhost:3000

# ─── Core AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here

# ─── Discovery Sources (all optional — enable as needed) ────
# Serper: Google LinkedIn SERP (primary discovery)
SERPER_API_KEY=your-key-here

# Apollo.io: B2B people & company database
APOLLO_API_KEY=your-key-here

# Bing Web Search: LinkedIn SERP via Bing (fallback)
BING_SEARCH_KEY=your-key-here

# ─── Enrichment Sources (all optional) ──────────────────────
# Proxycurl: LinkedIn profile enrichment (primary enrichment)
PROXYCURL_API_KEY=your-key-here

# Hunter.io: Professional email finder
HUNTER_API_KEY=your-key-here

# Clearbit: Company data enrichment
CLEARBIT_API_KEY=your-key-here

# ─── Outreach ────────────────────────────────────────────────
# PhantomBuster: LinkedIn message automation
PHANTOMBUSTER_API_KEY=your-key-here

NODE_ENV=development
